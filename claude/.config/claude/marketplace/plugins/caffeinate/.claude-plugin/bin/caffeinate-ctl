#!/bin/bash
set -euo pipefail

ACTION="${1:?Usage: caffeinate-ctl activate|deactivate <session_id>}"
SESSION_ID="${2:?Usage: caffeinate-ctl activate|deactivate <session_id>}"

PID_FILE="/tmp/claude-caffeinate-${SESSION_ID}.pid"

activate() {
    # If PID file exists and process is alive, nothing to do
    if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        return 0
    fi

    # Start caffeinate in background
    # -d: prevent display sleep
    # -i: prevent idle sleep
    # -s: prevent system sleep (AC power only)
    caffeinate -dis &
    echo $! > "$PID_FILE"
}

deactivate() {
    if [ -f "$PID_FILE" ]; then
        kill "$(cat "$PID_FILE")" 2>/dev/null || true
        rm -f "$PID_FILE"
    fi
}

case "$ACTION" in
    activate)   activate ;;
    deactivate) deactivate ;;
    *)          echo "Unknown action: $ACTION" >&2; exit 1 ;;
esac
