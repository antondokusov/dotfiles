#!/bin/bash
set -euo pipefail

ACTION="${1:?Usage: caffeinate-ctl activate|deactivate|stop <session_id> [has_background]}"
SESSION_ID="${2:?Usage: caffeinate-ctl activate|deactivate|stop <session_id> [has_background]}"
HAS_BACKGROUND="${3:-false}"

PID_FILE="/tmp/claude-caffeinate-${SESSION_ID}.pid"

activate() {
    # If PID file exists and process is alive, nothing to do
    if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        return 0
    fi

    # Start caffeinate in background, detached from hook shell
    # -d: prevent display sleep
    # -i: prevent idle sleep
    # -s: prevent system sleep (AC power only)
    nohup caffeinate -dis &>/dev/null &
    echo $! > "$PID_FILE"
}

deactivate() {
    if [ -f "$PID_FILE" ]; then
        kill "$(cat "$PID_FILE")" 2>/dev/null || true
        rm -f "$PID_FILE"
    fi
}

case "$ACTION" in
    activate)   activate ;;
    deactivate) deactivate ;;
    stop)
        # Stop / StopFailure. Keep awake while background work (background Bash /
        # background subagents) is still running; otherwise the turn is done.
        if [ "$HAS_BACKGROUND" = "true" ]; then
            activate
        else
            deactivate
        fi
        ;;
    *)          echo "Unknown action: $ACTION" >&2; exit 1 ;;
esac
