#!/usr/bin/env bash
# zellij-tab-icon — manage icon prefixes on zellij tab names
#
# Usage:
#   zellij-tab-icon set <icon> --session-id <id>            # set an icon prefix
#   zellij-tab-icon stop <true|false> --session-id <id>     # Stop/StopFailure: 🤖 if background work runs, else 💬
#   zellij-tab-icon clear --session-id <id>                 # remove the prefix

set -euo pipefail

# Exit silently if not inside zellij
[ -n "${ZELLIJ:-}" ] || exit 0

ACTION="${1:-}"
shift || true

# Parse arguments. The positional ARG is an icon for `set`, or the
# "background work running?" boolean ("true"/"false") for `stop`.
ARG=""
SESSION_ID=""
while [ $# -gt 0 ]; do
  case "$1" in
    --session-id) SESSION_ID="$2"; shift 2 ;;
    *) ARG="$1"; shift ;;
  esac
done

if [ -z "$SESSION_ID" ]; then
  exit 1
fi

WORKING_ICON="🤖 "
WAITING_ICON="💬 "

CACHE_FILE="/tmp/zellij-tab-icon-${SESSION_ID}"

# Known Claude Code icon prefixes (only these are stripped)
CLAUDE_ICONS="🤖 |💬 "

get_tab_id() {
  if [ -f "$CACHE_FILE" ]; then
    cat "$CACHE_FILE"
  else
    local tab_id
    tab_id=$(zellij action current-tab-info --json | nu --stdin -c '$in | from json | get tab_id')
    echo "$tab_id" > "$CACHE_FILE"
    echo "$tab_id"
  fi
}

get_tab_name() {
  local tab_id="$1"
  zellij action list-tabs --json | nu --stdin -c "\$in | from json | where tab_id == ${tab_id} | first | get name"
}

strip_claude_icons() {
  local name="$1"
  # Strip known Claude icon prefixes from anywhere in the name
  echo "$name" | sed -E "s/${CLAUDE_ICONS}//g"
}

apply_icon() {
  local icon="$1"
  local tab_id current_name base_name
  tab_id=$(get_tab_id)
  current_name=$(get_tab_name "$tab_id")
  base_name=$(strip_claude_icons "$current_name")
  zellij action rename-tab "${icon}${base_name}" --tab-id "$tab_id"
}

clear_icon() {
  if [ ! -f "$CACHE_FILE" ]; then
    return 0
  fi
  local tab_id current_name base_name
  tab_id=$(cat "$CACHE_FILE")
  current_name=$(get_tab_name "$tab_id")
  base_name=$(strip_claude_icons "$current_name")
  zellij action rename-tab "$base_name" --tab-id "$tab_id"
  rm -f "$CACHE_FILE"
}

case "$ACTION" in
  set)
    if [ -z "$ARG" ]; then
      exit 1
    fi
    apply_icon "$ARG"
    ;;
  stop)
    # Stop / StopFailure: ARG is "true" while background work is still running.
    if [ "$ARG" = "true" ]; then
      apply_icon "$WORKING_ICON"
    else
      apply_icon "$WAITING_ICON"
    fi
    ;;
  clear)
    clear_icon
    ;;
  *)
    echo "Usage: zellij-tab-icon {set|stop|clear} [arg] --session-id <id>" >&2
    exit 1
    ;;
esac
